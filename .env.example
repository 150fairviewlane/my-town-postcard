# ─── Database ────────────────────────────────────────────────────────────────
# Automatically provisioned by Replit — do not set manually in development
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys for production
STRIPE_SECRET_KEY=sk_test_...

# ─── Stripe (Frontend) ───────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys (publishable key)
# Add to Replit Secrets as VITE_STRIPE_PUBLISHABLE_KEY
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# The email address where admin order notifications are sent
ADMIN_EMAIL=you@yourdomain.com

# The "from" address for customer emails (must be verified in Resend)
FROM_EMAIL=noreply@yourdomain.com

# ─── Cloudinary (Ad File Uploads) ────────────────────────────────────────────
# Get from: https://cloudinary.com/console
# Create an upload preset: Settings → Upload → Upload presets → Add upload preset
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── Admin ───────────────────────────────────────────────────────────────────
# The password used to log in to /admin dashboard
ADMIN_PASSWORD=choose-a-strong-password-here

# Used to sign admin JWT tokens — set to a long random string
SESSION_SECRET=replace-with-a-long-random-string

# ─── App URL (for email links) ───────────────────────────────────────────────
# The public URL of your deployed app
APP_URL=https://your-app.replit.app
