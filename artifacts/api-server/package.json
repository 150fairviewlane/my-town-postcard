{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:prompt-size": "tsx src/scripts/check-prompt-size.ts",
    "test:transforms": "tsx src/scripts/test-transforms.ts",
    "test:transforms:neighborhood-pro": "tsx src/scripts/test-transforms.ts --template=neighborhood-pro",
    "analyze:transforms": "tsx src/scripts/analyze-transforms.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@types/express-session": "^1.19.0",
    "@types/pdfkit": "^0.17.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "@swc/helpers": "^0.5.0",
    "pdfkit": "^0.19.1",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/sharp": "^0.32.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
