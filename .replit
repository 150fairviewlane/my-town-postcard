modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "prompt-size-guard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Prompt size guard"

[[workflows.workflow]]
name = "prompt-size-guard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run check:prompt-size"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Prompt size guard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run check:prompt-size"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 4173
externalPort = 4200

[[ports]]
localPort = 4174
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 22490
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
STRIPE_FORCE_TEST_MODE = "1"
STRIPE_LIVE_SECRET_KEY = "placeholder"
STRIPE_LIVE_PUBLISHABLE_KEY = "placeholder"
